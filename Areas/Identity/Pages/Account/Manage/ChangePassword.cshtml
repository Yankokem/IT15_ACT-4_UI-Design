@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
    Layout = "~/Views/Shared/_IdentityLayout.cshtml";
}

<h3 class="mb-4">
    <i class="bi bi-key"></i> @ViewData["Title"]
</h3>

<div class="alert alert-info" role="alert">
    <i class="bi bi-info-circle"></i> Make sure to use a strong password that you don't use anywhere else.
</div>

@{
    var statusMessage = (string)ViewData["StatusMessage"];
}

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @statusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-md-6">
        <form id="change-password-form" method="post">
            @if (ViewData.ModelState[""] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <strong>Error!</strong>
                    <div asp-validation-summary="ModelOnly"></div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="form-floating mb-3">
                <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Please enter your old password." data-bs-toggle="tooltip" title="Enter your current password" />
                <label asp-for="Input.OldPassword" class="form-label">
                    <i class="bi bi-lock"></i> Old Password
                </label>
                <span asp-validation-for="Input.OldPassword" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Please enter your new password." data-bs-toggle="tooltip" title="Choose a new strong password" />
                <label asp-for="Input.NewPassword" class="form-label">
                    <i class="bi bi-lock-fill"></i> New Password
                </label>
                <span asp-validation-for="Input.NewPassword" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Please confirm your new password." data-bs-toggle="tooltip" title="Confirm your new password" />
                <label asp-for="Input.ConfirmPassword" class="form-label">
                    <i class="bi bi-lock-check"></i> Confirm Password
                </label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small d-block mt-1"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100">
                <i class="bi bi-check-lg"></i> Update password
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Initialize Bootstrap tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            })
        });
    </script>
}
